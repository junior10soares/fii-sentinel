# pipeline/ (GitHub Actions secrets)
GEMINI_API_KEY=
GROQ_API_KEY=

# compartilhado pipeline/ e app/
# Dashboard do Supabase renomeou "service_role"/"anon" para "Secret key"/
# "Publishable key" (formato novo: sb_secret_.../sb_publishable_...) — o JWT
# antigo ainda funciona em paralelo, mas a chave nova é a indicada agora.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# app/ (Vercel env vars, lado do cliente)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# app/ (Vercel env vars, server-only — nunca prefixar com NEXT_PUBLIC_)
GH_PAT=
